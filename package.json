{
  "name": "divido-monorepo",
  "version": "1.0.0",
  "description": "Divido - Expense Sharing Application",
  "private": true,
  "scripts": {
    "setup": "node setup.js",
    "dev": "concurrently \"cd server && npm run dev\" \"cd web && npm run dev\"",
    "build": "npm run build --workspace=server && npm run build --workspace=web",
    "server": "cd server && npm run dev",
    "client": "cd web && npm run dev"
  },
  "workspaces": [
    "server",
    "web"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "expense",
    "sharing",
    "split",
    "money",
    "group"
  ],
  "author": "Your Name",
  "license": "MIT"
}
